{
  "layer": "top",
  "position": "top",
  "height": 28,

  "modules-left": [
    "hyprland/workspaces"
  ],

  "modules-center": [
    "hyprland/window"
  ],

  "modules-right": [
    "network",
    "pulseaudio",
    "battery",
    "clock",
    "tray"
  ],

  "hyprland/workspaces": {
    "disable-scroll": false,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1"
  },

  "network": {
    "format-wifi": "  {signalStrength}%",
    "format-ethernet": "󰈀",
    "format-disconnected": "󰖪",
    "tooltip": true,
    "tooltip-format": "{essid}\n{ipaddr}",
    "on-click": "nm-connection-editor"
  },

  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-muted": "󰖁",
    "format-icons": {
      "default": ["", "", ""]
    },
    "on-click": "pavucontrol"
  },

  "battery": {
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% ",
    "format-icons": ["", "", "", "", ""]
  },

  "clock": {
    "interval": 60,
    "format": "{:%a %d %b %Y %H:%M}",
    "tooltip-format": "{:%A %d %B %Y}"
  }
}
